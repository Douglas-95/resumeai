# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/resumeai"

# ─── Redis / BullMQ ──────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="resumes"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Escolha: "claude" ou "openai"
AI_PROVIDER="claude"

# ─── Anthropic / Claude ──────────────────────────────────────────────────────
# Só necessário se AI_PROVIDER=claude
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"
ANTHROPIC_MAX_TOKENS=8192

# ─── OpenAI / GPT ────────────────────────────────────────────────────────────
# Só necessário se AI_PROVIDER=openai
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
OPENAI_MAX_TOKENS=8192

# ─── BullMQ Worker ───────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
AI_JOB_RETRY_ATTEMPTS=3
AI_JOB_RETRY_DELAY_MS=2000
